
# key that other services use to call gateway
API_KEY=

# docker service names are used when running via docker compose
FALL_DETECTION_URL=http://fall-detection:8001
FIRE_DETECTION_URL=http://fire-detection:8002
VIOLENCE_DETECTION_URL=http://violence-detection:8003
BURGLARY_DETECTION_URL=http://burglary-detection:8004
THEFT_DETECTION_URL=http://theft-detection:8005

# in local
#FALL_DETECTION_URL=http://localhost:8001
#FIRE_DETECTION_URL=http://localhost:8002
#VIOLENCE_DETECTION_URL=http://localhost:8003

# Go backend integration
# URL of qamqor-vision-backend
BACKEND_URL=http://qamqor-vision-backend:8080
# key for authenticating requests to go backend
BACKEND_API_KEY=

# stream processor
# how often to sample one frame per camera (seconds)
FRAME_INTERVAL_SEC=1.0
# minimum seconds between alerts for the same camera (prevents spam)
ALERT_COOLDOWN_SEC=30
# how often to refresh camera list from backend (seconds)
CAMERA_REFRESH_SEC=60
